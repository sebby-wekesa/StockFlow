generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String?
  role                 Role                  @default(PENDING)
  department           String?
  organizationId       String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  auditLogs            AuditLog[]
  importBatches        ImportBatch[]
  notificationSettings NotificationSettings?
  stageLogs            StageLog[]
  branches             Branch[]
  organization         Organization?         @relation(fields: [organizationId], references: [id])
}

model Design {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  description      String?
  targetDimensions String?
  targetWeight     Decimal?          @db.Decimal(10, 4)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  bomItems         BillOfMaterials[]
  finishedGoods    FinishedGoods[]
  productionOrders ProductionOrder[]
  stages           Stage[]
}

model Stage {
  id              String                   @id @default(cuid())
  name            String
  department      String
  sequence        Int
  designId        String
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  consumptionLogs MaterialConsumptionLog[]
  design          Design                   @relation(fields: [designId], references: [id], onDelete: Cascade)
  stageLogs       StageLog[]

  @@unique([designId, sequence])
}

model ProductionOrder {
  id              String                   @id @default(cuid())
  orderNumber     String                   @unique
  designId        String
  quantity        Int                      @default(1)
  targetKg        Decimal                  @db.Decimal(10, 4)
  status          ProductionStatus         @default(PENDING)
  priority        Priority                 @default(MEDIUM)
  currentStage    Int                      @default(1)
  currentDept     String?
  assignedTo      String?
  approvedBy      String?
  approvedAt      DateTime?
  completedAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  consumptionLogs MaterialConsumptionLog[]
  design          Design                   @relation(fields: [designId], references: [id])
  logs            StageLog[]
}

model StageLog {
  id          String          @id @default(cuid())
  orderId     String
  stageId     String?
  stageName   String
  sequence    Int
  kgIn        Decimal         @db.Decimal(10, 4)
  kgOut       Decimal         @db.Decimal(10, 4)
  kgScrap     Decimal         @db.Decimal(10, 4)
  scrapReason String?
  department  String?
  operatorId  String
  notes       String?
  completedAt DateTime        @default(now())
  operator    User            @relation(fields: [operatorId], references: [id])
  order       ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stage       Stage?          @relation(fields: [stageId], references: [id])
}

model RawMaterial {
  id              String                   @id @default(cuid())
  sku             String                   @unique
  materialName    String
  diameter        String
  supplierId      String?
  barcode         String?                  @unique
  batchNumber     String?
  availableKg     Decimal                  @default(0) @db.Decimal(10, 4)
  reservedKg      Decimal                  @default(0) @db.Decimal(10, 4)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  bomItems        BillOfMaterials[]
  forecasts       DemandForecast[]
  inventories     InventoryRawMaterial[]
  consumptionLogs MaterialConsumptionLog[]
  receipts        MaterialReceipt[]
  purchaseItems   PurchaseOrderItem[]
  supplier        Supplier?                @relation(fields: [supplierId], references: [id])
}

model MaterialReceipt {
  id         String      @id @default(cuid())
  materialId String
  kgReceived Decimal     @db.Decimal(10, 4)
  reference  String?
  supplierId String?
  branchId   String?
  loggedBy   String?
  createdAt  DateTime    @default(now())
  branch     Branch?     @relation(fields: [branchId], references: [id])
  material   RawMaterial @relation(fields: [materialId], references: [id])
  supplier   Supplier?   @relation(fields: [supplierId], references: [id])
}

model FinishedGoods {
  id          String                   @id @default(cuid())
  sku         String                   @unique
  designId    String
  quantity    Int
  kgProduced  Decimal                  @db.Decimal(10, 4)
  barcode     String?                  @unique
  batchNumber String?
  createdAt   DateTime                 @default(now())
  design      Design                   @relation(fields: [designId], references: [id])
  inventories InventoryFinishedGoods[]
  saleItems   SaleItem[]
}

model Product {
  id           String           @id @default(cuid())
  name         String
  sku          String?          @unique
  origin       StockOrigin      @default(FACTORY_MADE)
  uom          String
  currentStock Float            @default(0)
  unitCost     Float?
  landingCost  Float?
  vendor       String?
  branchId     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  branch       Branch?          @relation(fields: [branchId], references: [id])
  aliases      ProductAlias[]
  receipts     ProductReceipt[]
}

model ProductReceipt {
  id          String   @id @default(cuid())
  productId   String
  qtyReceived Float
  unitCost    Float?
  landingCost Float?
  reference   String?
  vendor      String?
  loggedBy    String?
  branchId    String?
  createdAt   DateTime @default(now())
  branch      Branch?  @relation(fields: [branchId], references: [id])
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryRawMaterial {
  id            String      @id @default(cuid())
  branchId      String
  rawMaterialId String
  availableKg   Decimal     @default(0) @db.Decimal(10, 4)
  reservedKg    Decimal     @default(0) @db.Decimal(10, 4)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([branchId, rawMaterialId])
}

model InventoryFinishedGoods {
  id              String        @id @default(cuid())
  branchId        String
  finishedGoodsId String
  availableQty    Int           @default(0)
  reservedQty     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  finishedGoods   FinishedGoods @relation(fields: [finishedGoodsId], references: [id], onDelete: Cascade)

  @@unique([branchId, finishedGoodsId])
}

model BillOfMaterials {
  id            String      @id @default(cuid())
  designId      String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(10, 4)
  unitOfMeasure String      @default("kg")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  design        Design      @relation(fields: [designId], references: [id], onDelete: Cascade)
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([designId, rawMaterialId])
}

model MaterialConsumptionLog {
  id                String          @id @default(cuid())
  productionOrderId String
  rawMaterialId     String
  quantityConsumed  Decimal         @db.Decimal(10, 4)
  consumedAt        DateTime        @default(now())
  stageId           String?
  notes             String?
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  rawMaterial       RawMaterial     @relation(fields: [rawMaterialId], references: [id])
  stage             Stage?          @relation(fields: [stageId], references: [id])
}

model SaleOrder {
  id           String     @id @default(cuid())
  customerId   String?
  customerName String
  totalAmount  Decimal    @db.Decimal(10, 2)
  status       SaleStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  items        SaleItem[]
  customer     Customer?  @relation(fields: [customerId], references: [id])
}

model SaleItem {
  id              String        @id @default(cuid())
  saleOrderId     String
  finishedGoodsId String
  quantity        Int
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  finishedGoods   FinishedGoods @relation(fields: [finishedGoodsId], references: [id])
  saleOrder       SaleOrder     @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id               String              @id @default(cuid())
  poNumber         String              @unique
  supplierId       String
  status           PurchaseStatus      @default(DRAFT)
  totalAmount      Decimal             @db.Decimal(10, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  approvedBy       String?
  approvedAt       DateTime?
  expectedDelivery DateTime?
  notes            String?
  supplier         Supplier            @relation(fields: [supplierId], references: [id])
  items            PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  rawMaterialId   String
  quantity        Decimal       @db.Decimal(10, 4)
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  rawMaterial     RawMaterial   @relation(fields: [rawMaterialId], references: [id])
}

model DemandForecast {
  id               String      @id @default(cuid())
  rawMaterialId    String
  forecastDate     DateTime
  forecastedDemand Decimal     @db.Decimal(10, 4)
  confidenceLevel  Float
  basedOnDays      Int
  createdAt        DateTime    @default(now())
  rawMaterial      RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([rawMaterialId, forecastDate])
}

model CustomerPortalAccess {
  id         String    @id @default(cuid())
  customerId String    @unique
  accessCode String    @unique
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastLogin  DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id])
}

model NotificationSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  whatsappEnabled Boolean  @default(false)
  whatsappNumber  String?
  orderApproved   Boolean  @default(true)
  highScrapAlert  Boolean  @default(true)
  stockoutAlert   Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
  users     User[]
}

model Branch {
  id                  String                   @id @default(cuid())
  organizationId      String
  name                String                   @unique
  location            String?
  code                String                   @unique
  address             String?
  phone               String?
  managerId           String?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  organization        Organization             @relation(fields: [organizationId], references: [id])
  finishedInventories InventoryFinishedGoods[]
  rawInventories      InventoryRawMaterial[]
  receipts            MaterialReceipt[]
  products            Product[]
  productReceipts     ProductReceipt[]
  users               User[]
}

model Supplier {
  id             String            @id @default(cuid())
  name           String
  code           String            @unique
  contactName    String?
  email          String?
  phone          String?
  address        String?
  taxId          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  receipts       MaterialReceipt[]
  purchaseOrders PurchaseOrder[]
  materials      RawMaterial[]
}

model Customer {
  id           String                @id @default(cuid())
  name         String
  code         String                @unique
  contactName  String?
  email        String?
  phone        String?
  address      String?
  taxId        String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  portalAccess CustomerPortalAccess?
  orders       SaleOrder[]
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  name      String
  symbol    String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model ImportBatch {
  id              String       @id @default(cuid())
  file_name       String
  sheet_type      String
  import_mode     ImportMode   @default(update)
  target_branch   String?
  status          ImportStatus @default(uploaded)
  row_count       Int
  created_by      String
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  created_by_user User         @relation(fields: [created_by], references: [id])
  rows            ImportRow[]
}

model ImportRow {
  id               String      @id @default(cuid())
  batch_id         String
  row_number       Int
  raw_data         Json
  mapped_data      Json?
  matched_product  String?
  match_confidence Float?
  resolution       String?
  resolved_product String?
  order_number     String?
  customer_name    String?
  qty              Float?
  unit_price       Float?
  notes            String?
  errors           String?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt
  batch            ImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@index([batch_id])
}

model ProductAlias {
  id         String   @id @default(cuid())
  product_id String
  alias      String
  created_at DateTime @default(now())
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, alias])
  @@index([alias])
}

enum Role {
  PENDING
  ADMIN
  MANAGER
  OPERATOR
  WAREHOUSE
  SALES
  PACKAGING
}

enum ProductionStatus {
  PENDING
  APPROVED
  IN_PRODUCTION
  COMPLETED
  REJECTED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum StockOrigin {
  FACTORY_MADE
  LOCAL_PURCHASE
  IMPORTED
}

enum PurchaseStatus {
  DRAFT
  APPROVED
  ORDERED
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  PENDING
  CONFIRMED
  INVOICED
  FULFILLED
  CANCELLED
}

enum ImportStatus {
  uploaded
  mapping
  validating
  preview
  committing
  imported
  failed
}

enum ImportMode {
  update
  ignore
  replace
}
