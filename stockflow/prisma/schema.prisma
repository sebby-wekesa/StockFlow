generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
enum Role {
  ADMIN
  MANAGER
  OPERATOR
  SALES
  PACKAGING
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  role       Role     @default(OPERATOR)
  department String?  // e.g., "Cutting", "Forging"
}

model Design {
  id      String            @id @default(cuid())
  name    String            // e.g., "Hex Bolt M12"
  stages  Stage[]
  orders  ProductionOrder[] 
}

model Stage {
  id        String @id @default(cuid())
  name      String // e.g., "Forging"
  sequence  Int
  designId  String
  design    Design @relation(fields: [designId], references: [id])
}

model ProductionOrder {
  id        String     @id @default(cuid())
  designId  String
  design    Design     @relation(fields: [designId], references: [id])
  status    String     @default("PENDING") // PENDING, APPROVED, COMPLETED
  logs      StageLog[]
  createdAt DateTime   @default(now())
}

model StageLog {
  id          String          @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id])
  department  String
  kgIn        Float
  kgOut       Float
  kgScrap     Float
  operatorId  String
  completedAt DateTime        @default(now())
}