  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  MaterialConsumptionLog MaterialConsumptionLog[]
  Design                 Design                   @relation(fields: [designId], references: [id], onDelete: Cascade)
  StageLog               StageLog[]

  @@unique([designId, sequence])
  @@schema("public")
}

model StageLog {
  id              String          @id
  orderId         String
  stageId         String?
  stageName       String
  sequence        Int
  kgIn            Decimal         @db.Decimal(10, 4)
  kgOut           Decimal         @db.Decimal(10, 4)
  kgScrap         Decimal         @db.Decimal(10, 4)
  scrapReason     String?
  department      String?
  operatorId      String
  notes           String?
  completedAt     DateTime        @default(now())
  User            User            @relation(fields: [operatorId], references: [id])
  ProductionOrder ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Stage           Stage?          @relation(fields: [stageId], references: [id])

  @@schema("public")
}

model Supplier {
  id              String            @id
  name            String
  code            String            @unique
  contactName     String?
  email           String?
  phone           String?
  address         String?
  taxId           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  MaterialReceipt MaterialReceipt[]
  PurchaseOrder   PurchaseOrder[]
  RawMaterial     RawMaterial[]

  @@schema("public")
}

model UnitOfMeasure {
  id        String   @id
  name      String
  symbol    String
  category  String
