  users            users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id])
  @@schema("auth")
}

model AuditLog {
  id         String   @id
  userId     String
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id])

  @@schema("public")
}

model BillOfMaterials {
  id            String      @id
  designId      String
  rawMaterialId String
  quantity      Decimal     @db.Decimal(10, 4)
  unitOfMeasure String      @default("kg")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  Design        Design      @relation(fields: [designId], references: [id], onDelete: Cascade)
  RawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([designId, rawMaterialId])
  @@schema("public")
}

model Branch {
  id                     String                   @id
  organizationId         String
  name                   String                   @unique
  location               String?
  code                   String                   @unique
  address                String?
  phone                  String?
  managerId              String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  Organization           Organization             @relation(fields: [organizationId], references: [id])
  InventoryFinishedGoods InventoryFinishedGoods[]
  InventoryRawMaterial   InventoryRawMaterial[]
  MaterialReceipt        MaterialReceipt[]
  Product                Product[]
  ProductReceipt         ProductReceipt[]
  User                   User[]

  @@schema("public")
}

model Customer {
  id                   String                @id
  name                 String
  code                 String                @unique
  contactName          String?
  email                String?
  phone                String?
  address              String?
  taxId                String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  CustomerPortalAccess CustomerPortalAccess?
  SaleOrder            SaleOrder[]

  @@schema("public")
}

model CustomerPortalAccess {
  id         String    @id
  customerId String    @unique
  accessCode String    @unique
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastLogin  DateTime?
  Customer   Customer  @relation(fields: [customerId], references: [id])

  @@schema("public")
}

model DemandForecast {
  id               String      @id
  rawMaterialId    String
  forecastDate     DateTime
  forecastedDemand Decimal     @db.Decimal(10, 4)
  confidenceLevel  Float
  basedOnDays      Int
  createdAt        DateTime    @default(now())
  RawMaterial      RawMaterial @relation(fields: [rawMaterialId], references: [id])

  @@unique([rawMaterialId, forecastDate])
  @@schema("public")
}

model Design {
  id               String            @id
  name             String
  code             String            @unique
  description      String?
  targetDimensions String?
  targetWeight     Decimal?          @db.Decimal(10, 4)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  BillOfMaterials  BillOfMaterials[]
  FinishedGoods    FinishedGoods[]
  ProductionOrder  ProductionOrder[]
  Stage            Stage[]

  @@schema("public")
}

model FinishedGoods {
  id                     String                   @id
  sku                    String                   @unique
  designId               String
  quantity               Int
  kgProduced             Decimal                  @db.Decimal(10, 4)
  barcode                String?                  @unique
  batchNumber            String?
  createdAt              DateTime                 @default(now())
  Design                 Design                   @relation(fields: [designId], references: [id])
  InventoryFinishedGoods InventoryFinishedGoods[]
  SaleItem               SaleItem[]

  @@schema("public")
}

model ImportBatch {
  id            String       @id
  file_name     String
  sheet_type    String
  import_mode   ImportMode   @default(update)
  target_branch String?
  status        ImportStatus @default(uploaded)
  row_count     Int
  created_by    String
  created_at    DateTime     @default(now())
  updated_at    DateTime
  User          User         @relation(fields: [created_by], references: [id])
  ImportRow     ImportRow[]

  @@schema("public")
}

model ImportRow {
  id               String      @id
  batch_id         String
  row_number       Int
  raw_data         Json
  mapped_data      Json?
  matched_product  String?
  match_confidence Float?
  resolution       String?
  resolved_product String?
  order_number     String?
  customer_name    String?
  qty              Float?
  unit_price       Float?
  notes            String?
  errors           String?
  created_at       DateTime    @default(now())
  updated_at       DateTime
  ImportBatch      ImportBatch @relation(fields: [batch_id], references: [id], onDelete: Cascade)

  @@index([batch_id])
  @@schema("public")
}

model InventoryFinishedGoods {
  id              String        @id
  branchId        String
  finishedGoodsId String
  availableQty    Int           @default(0)
  reservedQty     Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime
  Branch          Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  FinishedGoods   FinishedGoods @relation(fields: [finishedGoodsId], references: [id], onDelete: Cascade)

  @@unique([branchId, finishedGoodsId])
  @@schema("public")
}

model InventoryRawMaterial {
  id            String      @id
  branchId      String
  rawMaterialId String
  availableKg   Decimal     @default(0) @db.Decimal(10, 4)
  reservedKg    Decimal     @default(0) @db.Decimal(10, 4)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime
  Branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  RawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([branchId, rawMaterialId])
  @@schema("public")
}

model MaterialConsumptionLog {
  id                String          @id
  productionOrderId String
  rawMaterialId     String
  quantityConsumed  Decimal         @db.Decimal(10, 4)
  consumedAt        DateTime        @default(now())
  stageId           String?
  notes             String?
  ProductionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  RawMaterial       RawMaterial     @relation(fields: [rawMaterialId], references: [id])
  Stage             Stage?          @relation(fields: [stageId], references: [id])

  @@schema("public")
}

model MaterialReceipt {
  id          String      @id
  materialId  String
  kgReceived  Decimal     @db.Decimal(10, 4)
  reference   String?
  supplierId  String?
  branchId    String?
  loggedBy    String?
  createdAt   DateTime    @default(now())
  Branch      Branch?     @relation(fields: [branchId], references: [id])
  RawMaterial RawMaterial @relation(fields: [materialId], references: [id])
  Supplier    Supplier?   @relation(fields: [supplierId], references: [id])

  @@schema("public")
}

model NotificationSettings {
  id              String   @id
  userId          String   @unique
  emailEnabled    Boolean  @default(true)
  whatsappEnabled Boolean  @default(false)
  whatsappNumber  String?
  orderApproved   Boolean  @default(true)
  highScrapAlert  Boolean  @default(true)
  stockoutAlert   Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime
  User            User     @relation(fields: [userId], references: [id])

  @@schema("public")
}

model Organization {
  id        String   @id
  name      String
  code      String   @unique
  address   String?
  phone     String?
  email     String?
  createdAt DateTime @default(now())
  updatedAt DateTime
  Branch    Branch[]
  User      User[]

  @@schema("public")
}

model Product {
  id             String           @id
  name           String
  sku            String?          @unique
  origin         StockOrigin      @default(FACTORY_MADE)
  uom            String
  currentStock   Float            @default(0)
  unitCost       Float?
  landingCost    Float?
  vendor         String?
  branchId       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  Branch         Branch?          @relation(fields: [branchId], references: [id])
  ProductAlias   ProductAlias[]
  ProductReceipt ProductReceipt[]

  @@schema("public")
}

model ProductAlias {
  id         String   @id
  product_id String
  alias      String
  created_at DateTime @default(now())
  Product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, alias])
  @@index([alias])
  @@schema("public")
}

model ProductReceipt {
  id          String   @id
  productId   String
  qtyReceived Float
  unitCost    Float?
  landingCost Float?
  reference   String?
  vendor      String?
  loggedBy    String?
  branchId    String?
  createdAt   DateTime @default(now())
  Branch      Branch?  @relation(fields: [branchId], references: [id])
  Product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model ProductionOrder {
  id                     String                   @id
  orderNumber            String                   @unique
  designId               String
  quantity               Int                      @default(1)
  targetKg               Decimal                  @db.Decimal(10, 4)
  status                 ProductionStatus         @default(PENDING)
  priority               Priority                 @default(MEDIUM)
  currentStage           Int                      @default(1)
  currentDept            String?
  assignedTo             String?
  approvedBy             String?
  approvedAt             DateTime?
  completedAt            DateTime?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
