  Design                 Design                   @relation(fields: [designId], references: [id])
  StageLog               StageLog[]

  @@schema("public")
}

model PurchaseOrder {
  id                String              @id
  poNumber          String              @unique
  supplierId        String
  status            PurchaseStatus      @default(DRAFT)
  totalAmount       Decimal             @db.Decimal(10, 2)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  approvedBy        String?
  approvedAt        DateTime?
  expectedDelivery  DateTime?
  notes             String?
