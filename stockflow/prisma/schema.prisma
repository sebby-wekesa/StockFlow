  RawMaterial     RawMaterial   @relation(fields: [rawMaterialId], references: [id])

  @@schema("public")
}

model RawMaterial {
  id                     String                   @id
  sku                    String                   @unique
  materialName           String
  diameter               String
  supplierId             String?
  barcode                String?                  @unique
  batchNumber            String?
  availableKg            Decimal                  @default(0) @db.Decimal(10, 4)
  reservedKg             Decimal                  @default(0) @db.Decimal(10, 4)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  BillOfMaterials        BillOfMaterials[]
  DemandForecast         DemandForecast[]
  InventoryRawMaterial   InventoryRawMaterial[]
  MaterialConsumptionLog MaterialConsumptionLog[]
  MaterialReceipt        MaterialReceipt[]
  PurchaseOrderItem      PurchaseOrderItem[]
  Supplier               Supplier?                @relation(fields: [supplierId], references: [id])

  @@schema("public")
}

model SaleItem {
  id              String        @id
  saleOrderId     String
  finishedGoodsId String
  quantity        Int
  unitPrice       Decimal       @db.Decimal(10, 2)
  totalPrice      Decimal       @db.Decimal(10, 2)
  FinishedGoods   FinishedGoods @relation(fields: [finishedGoodsId], references: [id])
  SaleOrder       SaleOrder     @relation(fields: [saleOrderId], references: [id], onDelete: Cascade)

  @@schema("public")
}

model SaleOrder {
  id           String     @id
  customerId   String?
  customerName String
  totalAmount  Decimal    @db.Decimal(10, 2)
  status       SaleStatus @default(PENDING)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  SaleItem     SaleItem[]
  Customer     Customer?  @relation(fields: [customerId], references: [id])

  @@schema("public")
}

model Stage {
  id                     String                   @id
  name                   String
  department             String
  sequence               Int
